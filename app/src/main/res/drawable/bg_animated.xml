<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Плавный перелив 6 секунд -->
    <item android:duration="6000">
        <shape>
            <gradient
                android:startColor="@color/bg_light_1"
                android:endColor="@color/bg_light_2"
                android:angle="45"/>
        </shape>
    </item>
    <item android:duration="6000">
        <shape>
            <gradient
                android:startColor="@color/bg_light_2"
                android:endColor="@color/bg_light_3"
                android:angle="45"/>
        </shape>
    </item>
    <item android:duration="6000">
        <shape>
            <gradient
                android:startColor="@color/bg_light_3"
                android:endColor="@color/bg_light_1"
                android:angle="45"/>
        </shape>
    </item>
</animation-list>