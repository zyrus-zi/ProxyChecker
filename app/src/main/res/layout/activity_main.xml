<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <EditText
        android:id="@+id/etInput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@android:drawable/editbox_background"
        android:gravity="top|start"
        android:hint="Вставьте прокси (IP:PORT, ссылки ТГ, GitHub URL...)"
        android:inputType="textMultiLine"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etInput">

        <EditText
            android:id="@+id/etThreads"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Потоки"
            android:inputType="number"
            android:text="50" />

        <EditText
            android:id="@+id/etTimeout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Таймаут (мс)"
            android:inputType="number"
            android:text="5000" />

        <Spinner
            android:id="@+id/spinnerProtocol"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:entries="@array/protocols_array" />
    </LinearLayout>

    <!-- Панель управления проверкой -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutSettings">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Старт" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Пауза"
            android:enabled="false" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Стоп"
            android:enabled="false" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Готово: 0 / 0"
        app:layout_constraintTop_toBottomOf="@id/layoutControls"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/tvProgress" />

    <LinearLayout
        android:id="@+id/layoutTableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E0E0E0"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar">

        <CheckBox android:id="@+id/cbSelectAll" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="3" android:text="Адрес" android:textStyle="bold" />
        <TextView android:id="@+id/headerProtocol" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Тип ▼" android:textStyle="bold" android:textColor="@color/black" />
        <TextView android:id="@+id/headerPing" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Пинг ▼" android:textStyle="bold" android:textColor="@color/black" />
        <TextView android:id="@+id/headerCountry" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Страна ▼" android:textStyle="bold" android:textColor="@color/black" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutExport"
        app:layout_constraintTop_toBottomOf="@id/layoutTableHeader" />

    <LinearLayout
        android:id="@+id/layoutExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnExportTxt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сохранить TXT" />

        <Button
            android:id="@+id/btnExportTg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ссылки ТГ" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>